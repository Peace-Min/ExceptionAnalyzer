<Window x:Class="ExceptionAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExceptionAnalyzer" Height="520" Width="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 대상 경로 + 폴더 선택 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0"
                     VerticalContentAlignment="Center" Padding="4,0" Height="28"
                     ToolTip="분석할 프로젝트 폴더 경로 (직접 입력·붙여넣기 또는 [폴더 선택])"/>
            <Button x:Name="PickFolderButton" Grid.Column="1" Content="폴더 선택" Width="90" Height="28"
                    Margin="8,0,0,0" Click="PickFolder_Click"/>
        </Grid>

        <!-- Row 1: 분석 시작 + 결과 폴더 열기 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="AnalyzeButton" Content="분석 + 소스 자동수정" Width="170" Height="30" Click="Analyze_Click"/>
            <Button Content="결과 폴더 열기" Width="130" Height="30" Margin="8,0,0,0"
                    Click="OpenResult_Click"/>
        </StackPanel>

        <!-- Row 2: 로그 -->
        <TextBox x:Name="LogBox" Grid.Row="2" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

        <!-- Row 3: 상태 -->
        <TextBlock x:Name="StatusText" Grid.Row="3" Margin="0,8,0,0"
                   Text="상태: 대기 중"/>
    </Grid>
</Window>
